# =============================================================================
# OPC Console — environment variables
# Copy to .env.local and fill in. Every variable below is optional for
# `next build`; only Supabase is needed to actually log in and persist data.
# =============================================================================

# --- Supabase (required at runtime) ------------------------------------------
# Project URL from Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Public anon key (safe to expose to the browser; RLS protects the data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — server-only, NEVER expose to the browser. Used by trusted
# server jobs (e.g. ingestion, cron) that must bypass RLS. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI (Phase 3, optional — product works fully without any of these) -------
# Default provider when a workspace hasn't configured BYOK. Free tiers only.
# One of: gemini | groq
AI_PROVIDER=gemini
# Free-tier Google Gemini API key (used for the default Gemini Flash model).
GEMINI_API_KEY=
# Free-tier Groq API key (alternative fast/free inference).
GROQ_API_KEY=
# Default model id used when none is specified by an agent.
AI_DEFAULT_MODEL=gemini-2.0-flash

# --- Cron (Phase 3, optional) ------------------------------------------------
# Bearer secret protecting GET /api/cron/daily-brief; set to any random string in production
CRON_SECRET=

# --- Ingestion (Phase 2, optional) -------------------------------------------
# Shared secret required on inbound signal-ingest webhook calls
# (e.g. /api/ingest). Reject requests whose header doesn't match.
INGEST_SECRET=

# --- Stripe (Phase 2, optional) ----------------------------------------------
# Webhook signing secret from the Stripe dashboard. Only needed if/when
# billing is wired up; OPC has no paid-SaaS runtime dependency by default.
STRIPE_WEBHOOK_SECRET=
# Workspace id that incoming Stripe events are attributed to (a row from the
# `workspaces` table). Required for the Stripe webhook to know where to write.
STRIPE_WS_ID=
# Stripe restricted API key (read-only permissions). When set, the Metrics page
# will fetch your live account balance directly via the Stripe REST API (no SDK).
# Create a restricted key at https://dashboard.stripe.com/apikeys with at minimum
# "Balance: Read" permission. Leave blank to show "Not configured" on Metrics.
STRIPE_API_KEY=

# --- App ---------------------------------------------------------------------
# Public base URL of the deployed app (used for auth redirects / absolute URLs).
NEXT_PUBLIC_SITE_URL=https://opc.sophontex.com
